{
  "expo": {
    "name": "Yap Family",
    "slug": "yap-family-companion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "yapfamily",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yapfamily.companion",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Yap Family uses the camera for video calls.",
        "NSMicrophoneUsageDescription": "Yap Family uses the microphone for video calls."
      }
    },
    "android": {
      "package": "com.yapfamily.companion",
      "softwareKeyboardLayoutMode": "pan",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.WAKE_LOCK",
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.FOREGROUND_SERVICE_CAMERA",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.FOREGROUND_SERVICE_TYPE_MEDIA_PLAYBACK",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "plugins": [
      "@react-native-firebase/app",
      [
        "@stream-io/video-react-native-sdk",
        {
          "androidKeepCallAlive": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 35,
            "buildToolsVersion": "36.0.0",
            "minSdkVersion": 24,
            "kotlinVersion": "2.1.20",
            "packagingOptions": {
              "pickFirst": [
                "**/libc++_shared.so",
                "**/libfbjni.so",
                "**/libwebrtc.so",
                "**/libjsc.so"
              ]
            }
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png"
        }
      ],
      "expo-audio",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Yap Family to use the microphone for voice input.",
          "speechRecognitionPermission": "Allow Yap Family to use speech recognition.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ],
      "expo-font",
      "./plugins/withLockScreenCall"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "yap-family-home",
    "extra": {
      "eas": {
        "projectId": "dabe2935-3995-4c33-9f7c-8c97524fd457"
      }
    }
  }
}
